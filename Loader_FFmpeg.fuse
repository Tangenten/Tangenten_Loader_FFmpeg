--region Create
function Create()
	self:RemoveControlPage("Controls")
	self:AddControlPage("Controls", { CTID_DIB_ID = "Icons.Tools.Tabs.Image" })

	OutImage = self:AddOutput("Output", "Output", {
		LINKID_DataType = "Image",
		LINK_Main = 1,
		IMG_DeferAlloc = true,
		INP_AcceptsGPUImages = true,
	})

	InSectionInput = self:AddInput("", "SectionInput", {
		LINKID_DataType = "Number",
		INPID_InputControl = "LabelControl",
		LINKS_Name = "<b style='color:#b8c8d8;'>Input</b>",
		INP_Default = 1.0,
		LBLC_DropDownButton = true,
		LBLC_NumInputs = 2,
		LBLC_NestLevel = 1,
		IC_ControlPage = 0,
		INP_DoNotifyChanged = false,
		INP_InitialNotify = false,
		INP_External = false,
		INP_Passive = true,
		IC_NoLabel = true,
		IC_NoReset = true,
	})

	InInputPath = self:AddInput("Video Path", "InputPath", {
		INPID_InputControl = "FileControl",
		LINKID_DataType = "Text",
		LINKS_Name = "Path",
		IC_ControlPage = 0,
		FC_IsSaver = false,
		FC_ClipBrowse = true,
		FC_PathBrowse = false,
		FCS_FilterString = "Video Files (*.mov *.mp4 *.mkv *.avi *.webm *.m4v)|*.mov;*.mp4;*.mkv;*.avi;*.webm;*.m4v|All Files (*.*)|*.*|",
		INP_DoNotifyChanged = true,
		INP_InitialNotify = false,
		INP_External = false,
	})

	InMetadataStatus = self:AddInput("", "MetadataStatus", {
		LINKID_DataType = "Text",
		INPID_InputControl = "LabelControl",
		LINKS_Name = makeStatusHtml("No video loaded", { "Choose a video path and render a frame." }, false),
		IC_ControlPage = 0,
		INP_DoNotifyChanged = false,
		INP_InitialNotify = false,
		INP_External = false,
		INP_Passive = true,
		INP_Active = false,
		IC_NoLabel = true,
		IC_NoReset = true,
		LBLC_MultiLine = true,
	})

	InSectionPlayback = self:AddInput("", "SectionPlayback", {
		LINKID_DataType = "Number",
		INPID_InputControl = "LabelControl",
		LINKS_Name = "<b style='color:#c8b8d8;'>Playback</b>",
		INP_Default = 1.0,
		LBLC_DropDownButton = true,
		LBLC_NumInputs = 7,
		LBLC_NestLevel = 1,
		IC_ControlPage = 0,
		INP_DoNotifyChanged = false,
		INP_InitialNotify = false,
		INP_External = false,
		INP_Passive = true,
		IC_NoLabel = true,
		IC_NoReset = true,
	})

	InPlaybackMode = self:AddInput("Playback Mode", "PlaybackMode", {
		LINKID_DataType = "Number",
		INPID_InputControl = "ComboControl",
		INP_Default = 0,
		INP_Integer = true,
		INP_DoNotifyChanged = true,
		INP_InitialNotify = false,
		IC_ControlPage = 0,
		{ CCS_AddString = "Auto" },
		{ CCS_AddString = "Manual" },
	})

	InPlaybackFPS = self:AddInput("Playback FPS (0 = Source)", "PlaybackFPS", {
		LINKID_DataType = "Number",
		INPID_InputControl = "SliderControl",
		INP_Default = 0.0,
		INP_MinScale = 0.0,
		INP_MaxScale = 120.0,
		IC_DisplayedPrecision = 3,
		IC_ControlPage = 0,
	})

	InReverse = self:AddInput("Reverse Playback", "Reverse", {
		LINKID_DataType = "Number",
