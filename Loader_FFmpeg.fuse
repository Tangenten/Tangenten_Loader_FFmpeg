--endregion Create

--region NotifyChanged
local function updatePlaybackVisibility(mode)
	local manual = math.floor((mode or 0) + 0.5) == 1
	if InManualFrame then InManualFrame:SetAttrs({ IC_Visible = manual }) end
	if InPlaybackFPS then InPlaybackFPS:SetAttrs({ IC_Visible = not manual }) end
	if InReverse then InReverse:SetAttrs({ IC_Visible = not manual }) end
	if InLoopMode then InLoopMode:SetAttrs({ IC_Visible = not manual }) end
	if InStartFrame then InStartFrame:SetAttrs({ IC_Visible = true }) end
	if InEndFrame then InEndFrame:SetAttrs({ IC_Visible = true }) end
end

local function resetButton(input)
	if input and Number then
		input:SetSource(Number(0), 0, 0)
	end
end

function NotifyChanged(inp, param, time)
	if not param then return end

	if inp == InVersionFooter or inp == InLicenseFFmpeg then
		if bmd and bmd.openurl and param.Value then
			bmd.openurl(param.Value)
		end
		return
	end

	if inp == InInputPath then
		closeDecoder()
		setStatusHtml(makeStatusHtml("Video path changed", { "Render a frame to load metadata." }, false))
		return
	end

	if inp == InPlaybackMode then
		updatePlaybackVisibility(param.Value or 0)
		return
	end

	if inp == InTestsBtn and param.Value >= 0.5 then
		local ok, err = pcall(Tests)
		if not ok then
			logInfo("[tests] Tests crashed:", tostring(err))
		end
		resetButton(InTestsBtn)
		return
	end

	if inp == InReloadBtn and param.Value >= 0.5 then
		closeDecoder()
		local execute = string.format([[
local tool = comp:FindTool(%q)
if tool == nil then return end
tool.ScriptReload[fu.TIME_UNDEFINED] = 1
tool.ScriptReload[fu.TIME_UNDEFINED] = 0
]], self.Name)

		local ok, err = pcall(function()
			self.Comp:Execute(execute)
		end)
		if not ok then
			logInfo("[reload] Failed:", tostring(err))
		end
		resetButton(InReloadBtn)
		return
	end

	if inp == InWebsiteBtn and param.Value >= 0.5 then
		if bmd and bmd.openurl then
			bmd.openurl(TOOL_DEVELOPER_WEBSITE)
		end
		resetButton(InWebsiteBtn)
		return
	end
end
--endregion NotifyChanged

--region OnAddToFlow
function OnAddToFlow()
	updatePlaybackVisibility(0)
	if TOOL_RUN_TESTS_ON_STARTUP then
		Tests()
	end
end
--endregion OnAddToFlow

--region PreCalcProcess
-- Resolve the output resolution without decoding. ensureDecoder caches by path,
-- so the file is opened/probed once and every later precalc is a cheap cache
-- hit; opening only demuxes metadata and never seeks, so it leaves Process's
-- decode position untouched. Returns nil when there is no usable clip yet.
local function resolveVideoSize(req, comp)
	local pathValue = InInputPath and InInputPath:GetValue(req)
	local inputPath = pathValue and pathValue.Value or ""
	local mappedPath = mapCompPath(comp, inputPath)
	if mappedPath == "" or not fileExists(mappedPath) then
		return nil, nil, mappedPath
	end

	local decoder = ensureDecoder(mappedPath)
	if decoder and decoder.info and (decoder.info.width or 0) > 0 and (decoder.info.height or 0) > 0 then
		return decoder.info.width, decoder.info.height, mappedPath, decoder
	end

	return nil, nil, mappedPath
end

function PreCalcProcess(req)
	local width, height = resolveVideoSize(req, self.Comp)
	logInfo("[precalc] Output size", "width", width or 1, "height", height or 1)
	setNoDataOutput(self, req, width or 1, height or 1)
end
--endregion PreCalcProcess

--region Process
function Process(req)
	logInfo("[process] Start", "time", req.Time, "precalc", req:IsPreCalc(), "quick", req:IsQuick(), "noMotionBlur", req:IsNoMotionBlur())
	local pathValue = InInputPath:GetValue(req)
	local inputPath = pathValue and pathValue.Value or ""
	local mappedPath = mapCompPath(self.Comp, inputPath)
	logInfo("[process] Path values", "input", inputPath, "mapped", mappedPath)

	if req:IsPreCalc() then
		local width, height = resolveVideoSize(req, self.Comp)
		logInfo("[process] Precalc request", "width", width or 1, "height", height or 1)
		setNoDataOutput(self, req, width or 1, height or 1)
		return
	end

	if mappedPath == "" then
		logInfo("[process] No mapped path")
		setStatusHtml(makeStatusHtml("No video loaded", { "Choose a video path." }, false))
		setNoDataOutput(self, req, 1, 1)
		return
	end

	if not fileExists(mappedPath) then
		logInfo("[process] Missing input file", mappedPath)
		setErrorStatus("Input file missing", mappedPath)
		setNoDataOutput(self, req, 1, 1)
		return
	end

	local decoder, err = ensureDecoder(mappedPath)
	if not decoder then
		logInfo("[process] Decoder unavailable", tostring(err))
		setErrorStatus("LibAV load/open failed", err)
		setNoDataOutput(self, req, 1, 1)
		return
	end

	setInfoStatus(decoder.info, mappedPath)

	local frameIndex, blank = computeFrameIndex(req, decoder.info, self.Comp)
	logInfo("[process] Frame decision", "time", req.Time, "frameIndex", frameIndex, "blank", blank)
	if blank then
		logInfo("[process] Blank frame requested")
		setNoDataOutput(self, req, decoder.info.width, decoder.info.height)
		return
	end

	logInfo("[process] Decoding frame", frameIndex)
	local frame, decodeErr = decoder:decode(frameIndex)
	logInfo("[process] Decode result", "ok", frame ~= nil, "err", tostring(decodeErr), "bridgeDebug", LOADER_LIBAV.lastDebug and LOADER_LIBAV.lastDebug() or "")
	if not frame then
		setErrorStatus("Frame decode failed", decodeErr)
		setNoDataOutput(self, req, decoder.info.width, decoder.info.height)
		return
	end

	local outImg = createImage(self, req, frame.width, frame.height, false)
	logInfo("[process] Created output image", "width", tonumber(frame.width), "height", tonumber(frame.height), "hasGetScanLine", outImg.GetScanLine ~= nil)
	if not outImg.GetScanLine then
		setErrorStatus("Image output failed", "Fusion Image:GetScanLine is unavailable")
		setNoDataOutput(self, req, frame.width, frame.height)
		return
	end

	local ok, fromMemoryErr = copyFrameToImage(outImg, frame)
	if not ok then
		setErrorStatus("Image output failed", fromMemoryErr)
		setNoDataOutput(self, req, frame.width, frame.height)
		return
	end

	logInfo("[process] Setting output", "time", req.Time, "frameIndex", frameIndex, "reportedFrame", tonumber(frame.frame_index), "width", tonumber(frame.width), "height", tonumber(frame.height))
	OutImage:Set(req, outImg)
	logInfo("[process] Done", "time", req.Time, "frameIndex", frameIndex)
end
--endregion Process

--region Tests
function Tests()
	local failures = 0

	local function ok(name, condition)
		if condition then
			logInfo("[tests] OK", name)
		else
			failures = failures + 1
			logCritical("[tests] FAIL", name)
		end
	end

	ok("clamp low", clamp(-1, 0, 2) == 0)
	ok("clamp high", clamp(3, 0, 2) == 2)
	ok("umod negative", umod(-1, 4) == 3)
	ok("pingpong forward", pingpong(3, 4) == 3)
	ok("pingpong reverse", pingpong(4, 4) == 2)
	ok("html escape", escapeHtml([[<&">]]) == "&lt;&amp;&quot;&gt;")
	ok("frame count estimate", getInfoFrameCount({ frameCount = 0, duration = 2, fps = 24 }) == 48)

	if failures > 0 then
		logError(failures, "test(s) failed")
	end

	logInfo("[tests] All tests passed")
end

if not RUNNING_IN_FUSION and TOOL_RUN_TESTS_ON_STARTUP then
	Tests()
end
--endregion Tests
