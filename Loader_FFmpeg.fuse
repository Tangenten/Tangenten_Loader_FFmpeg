LOADER_LIBAV = LOADER_LIBAV
LOADER_LIBAV_ERROR = LOADER_LIBAV_ERROR
LOADER_DECODER = LOADER_DECODER
LOADER_DECODER_PATH = LOADER_DECODER_PATH
LOADER_STATUS_HTML = LOADER_STATUS_HTML

--region Logging
local function stringifyArgs(...)
	local parts = {}
	for i = 1, select("#", ...) do
		local v = select(i, ...)
		if type(v) == "table" then
			local tableParts = {}
			for k, value in pairs(v) do
				tableParts[#tableParts + 1] = tostring(k) .. "=" .. tostring(value)
			end
			parts[i] = "{" .. table.concat(tableParts, ", ") .. "}"
		else
			parts[i] = tostring(v)
		end
	end

	return table.concat(parts, " ")
end

if not dump then
	dump = function(...)
		print(stringifyArgs(...))
	end
end

local function logInfo(...)
	if not TOOL_ENABLE_LOGGING then return end
	dump("[" .. TOOL_NAME .. "]", ...)
end

local function logCritical(...)
	dump("[" .. TOOL_NAME .. "]", ...)
end

local function logError(...)
	error("[" .. TOOL_NAME .. "] " .. stringifyArgs(...), 2)
end

local function logAssert(condition, ...)
	if not condition then
		logError(...)
	end
end
--endregion Logging

--region Paths
local function getPathSeparator()
	return package.config:sub(1, 1)
end

local function getFuseDir()
	local sourceFile = debug.getinfo(1).source
	if sourceFile:sub(1, 1) == "@" then
		sourceFile = sourceFile:sub(2)
	end

	local fuseDir = sourceFile:match("^(.+)[/\\][^/\\]+$")
	if fuseDir then
		return fuseDir
	end

	logError("Fuse dir not found")
end

local function fileExists(path)
	if not path or path == "" then
		return false
	end

	local f = io.open(path, "rb")
	if f then
		f:close()
		return true
	end

	return false
end

local function mapCompPath(comp, path)
	if not path or path == "" then
		logInfo("[path] Empty input path")
		return ""
	end

	if comp and comp.MapPath then
		local ok, mapped = pcall(function()
			return comp:MapPath(path)
		end)
		if ok and mapped and mapped ~= "" then
			if mapped ~= path then
				logInfo("[path] Mapped", path, "->", mapped)
			else
				logInfo("[path] Path did not need mapping", path)
			end
			return mapped
		end
		if not ok then
			logInfo("[path] MapPath failed, using raw path:", tostring(mapped))
		end
	end

	logInfo("[path] Using raw path", path)
	return path
end
--endregion Paths

--region Pure helpers
local function clamp(v, lo, hi)
	if v < lo then return lo end
	if v > hi then return hi end
	return v
end

local function umod(a, n)
	if n <= 0 then return 0 end
	local r = a % n
	if r < 0 then r = r + n end
	return r
end

local function pingpong(i, n)
	if n <= 1 then return 0 end
	local len = (n * 2) - 2
	local m = umod(i, len)
	if m >= n then return len - m end
	return m
end

local function roundToInt(v)
	return math.floor(v + 0.5)
end

local function getCompFrameRate(comp)
	local fps
	if comp then
		local ok, v = pcall(function() return comp:GetPrefs("Comp.FrameFormat.Rate") end)
		if ok and type(v) == "number" and v > 0 then fps = v end

		if not fps then
			local ok2, t = pcall(function() return comp:GetPrefs("Comp.FrameFormat") end)
			if ok2 and type(t) == "table" and type(t.Rate) == "number" and t.Rate > 0 then
				fps = t.Rate
			end
		end

		if not fps then
			local ok3, attrs = pcall(function() return comp:GetAttrs() end)
			if ok3 and type(attrs) == "table" then
				if type(attrs.COMPN_GlobalFPS) == "number" and attrs.COMPN_GlobalFPS > 0 then
					fps = attrs.COMPN_GlobalFPS
				elseif type(attrs.COMPN_FrameRate) == "number" and attrs.COMPN_FrameRate > 0 then
					fps = attrs.COMPN_FrameRate
				end
			end
		end
	end

	return (type(fps) == "number" and fps > 0) and fps or 24.0
end

local function escapeHtml(text)
	text = tostring(text or "")
	text = text:gsub("&", "&amp;")
	text = text:gsub("<", "&lt;")
	text = text:gsub(">", "&gt;")
	text = text:gsub('"', "&quot;")
	return text
end

local function formatSeconds(seconds)
	if not seconds or seconds <= 0 then
		return "unknown"
	end

	return string.format("%.3fs", seconds)
end

local function formatFps(fps)
	if not fps or fps <= 0 then
		return "unknown"
	end

	return string.format("%.6g", fps)
end

local function getInfoFrameCount(info)
	if not info then return 0 end
	if info.frameCount and info.frameCount > 0 then
		return roundToInt(info.frameCount)
	end
	if info.duration and info.duration > 0 and info.fps and info.fps > 0 then
		return math.max(1, roundToInt(info.duration * info.fps))
	end

	return 0
end

local function computeFrameIndex(req, info, comp)
	local frameCount = getInfoFrameCount(info)
	if frameCount <= 0 then
		logInfo("[frame-map] Unknown frame count; using frame 0", "time", req.Time)
		return 0, false
	end

	local maxFrame = frameCount - 1
	local playbackMode = math.floor((InPlaybackMode:GetValue(req).Value or 0) + 0.5)
	local playbackFps = InPlaybackFPS:GetValue(req).Value or 0
	local reverse = (InReverse:GetValue(req).Value or 0) >= 0.5
	local loopMode = math.floor((InLoopMode:GetValue(req).Value or 0) + 0.5)
	local startFrame = math.max(0, roundToInt(InStartFrame:GetValue(req).Value or 0))
	local endFrame = math.max(0, roundToInt(InEndFrame:GetValue(req).Value or 0))
	local manualFrame = math.max(0, roundToInt(InManualFrame:GetValue(req).Value or 0))

	local startIdx = clamp(startFrame, 0, maxFrame)
	local endIdx = endFrame == 0 and maxFrame or clamp(endFrame - 1, startIdx, maxFrame)
	local subsetFrameCount = math.max(1, endIdx - startIdx + 1)

	local idxInSubset = 0
	local blank = false
	if playbackMode == 1 then
		idxInSubset = clamp(manualFrame, 0, subsetFrameCount - 1)
		logInfo("[frame-map] Manual", "time", req.Time, "manualFrame", manualFrame, "start", startIdx, "end", endIdx, "idxInSubset", idxInSubset)
	else
		local compFps = getCompFrameRate(comp)
		local sourceFps = info.fps and info.fps > 0 and info.fps or compFps
		local rate = playbackFps > 0 and playbackFps or sourceFps
		local logical = math.floor(((req.Time or 0) * (rate / compFps)) + 0.000001)
		if logical < 0 then logical = 0 end
		logInfo("[frame-map] Auto inputs", "time", req.Time, "compFps", compFps, "sourceFps", sourceFps, "playbackFps", playbackFps, "rate", rate, "logical", logical, "loopMode", loopMode, "reverse", reverse, "range", startIdx .. "-" .. endIdx)

		if loopMode == 0 then
			idxInSubset = umod(logical, subsetFrameCount)
		elseif loopMode == 1 then
			idxInSubset = pingpong(logical, subsetFrameCount)
		elseif loopMode == 2 then
			idxInSubset = logical >= subsetFrameCount and (subsetFrameCount - 1) or logical
		else
			if logical >= subsetFrameCount then
				blank = true
			else
				idxInSubset = logical
			end
		end
	end

	if reverse then
		idxInSubset = (subsetFrameCount - 1) - idxInSubset
	end

	local frameIndex = startIdx + idxInSubset
	logInfo("[frame-map] Result", "time", req.Time, "frameIndex", frameIndex, "idxInSubset", idxInSubset, "subsetFrameCount", subsetFrameCount, "blank", blank)
	return frameIndex, blank
end
--endregion Pure helpers

--region LibAV state
local function closeDecoder()
	if LOADER_DECODER and LOADER_DECODER.close then
		logInfo("[decode] Closing decoder", LOADER_DECODER_PATH or "<unknown>")
		local ok, err = pcall(function()
			LOADER_DECODER:close()
		end)
		if not ok then
			logInfo("[decode] close failed:", tostring(err))
		end
	end

	LOADER_DECODER = nil
	LOADER_DECODER_PATH = nil
	logInfo("[decode] Decoder state cleared")
end

local function loadLibAV()
	if LOADER_LIBAV then
		if LOADER_LIBAV.bridgeAbi == "abi2" then
			logInfo("[libav] Reusing loaded bridge", LOADER_LIBAV.version(), "path", LOADER_LIBAV.bridgePath or "<unknown>")
			return LOADER_LIBAV
		end

		logInfo("[libav] Dropping cached bridge without ABI2 tag", "path", LOADER_LIBAV.bridgePath or "<unknown>")
		LOADER_LIBAV = nil
	end
	if LOADER_LIBAV_ERROR then
		logInfo("[libav] Returning cached bridge error", LOADER_LIBAV_ERROR)
		return nil, LOADER_LIBAV_ERROR
	end

	local sep = getPathSeparator()
	local ffiPath = getFuseDir() .. sep .. "LibAV" .. sep .. "LibAV_FFI.lua"
	logInfo("[libav] Loading FFI wrapper", ffiPath)
	local ok, buildLibAV = pcall(dofile, ffiPath)
	if not ok then
		LOADER_LIBAV_ERROR = "Failed to load LibAV_FFI.lua: " .. tostring(buildLibAV)
		logInfo("[libav] FFI wrapper failed", LOADER_LIBAV_ERROR)
		return nil, LOADER_LIBAV_ERROR
	end

	logInfo("[libav] Building bridge from fuse dir", getFuseDir())
	local libAV, err = buildLibAV(getFuseDir())
	if not libAV then
		LOADER_LIBAV_ERROR = tostring(err)
		logInfo("[libav] Bridge build failed", LOADER_LIBAV_ERROR)
		return nil, LOADER_LIBAV_ERROR
	end

	LOADER_LIBAV = libAV
	logInfo("[libav] Loaded", libAV.version(), "dir", libAV.libDir or "<unknown>", "bridge", libAV.bridgePath or "<unknown>", "abi", libAV.bridgeAbi or "<unknown>")
	return LOADER_LIBAV
end

local function ensureDecoder(path)
	if LOADER_DECODER and LOADER_DECODER_PATH == path then
		if LOADER_LIBAV and LOADER_LIBAV.bridgeAbi == "abi2" then
			logInfo("[decode] Reusing decoder", path)
			return LOADER_DECODER
		end

		logInfo("[decode] Dropping cached decoder without ABI2 bridge", path)
		closeDecoder()
	end

	closeDecoder()

	local libAV, err = loadLibAV()
	if not libAV then
		return nil, err
	end

	local decoder, openErr = libAV.open(path)
	if not decoder then
		logInfo("[decode] Open failed", path, openErr, "bridgeDebug", libAV.lastDebug and libAV.lastDebug() or "")
		return nil, openErr
	end

	LOADER_DECODER = decoder
	LOADER_DECODER_PATH = path
	logInfo("[decode] Opened", path, "bridgeDebug", libAV.lastDebug and libAV.lastDebug() or "")
	logInfo("[decode] Metadata", "width", decoder.info.width, "height", decoder.info.height, "fps", decoder.info.fps, "frames", decoder.info.frameCount, "duration", decoder.info.duration, "codec", decoder.info.codecName, "pix", decoder.info.pixelFormat, "format", decoder.info.formatName)
	return LOADER_DECODER
end
--endregion LibAV state

--region Fusion image/status
local function makeStatusHtml(title, lines, isError)
	local color = isError and "#c8896a" or "#9fb7c9"
	local html = "<span style='color:" .. color .. ";'><b>" .. escapeHtml(title) .. "</b>"
	for i = 1, #lines do
		html = html .. "<br>" .. escapeHtml(lines[i])
	end
	return html .. "</span>"
end

local function setStatusHtml(html)
	if not RUNNING_IN_FUSION or not InMetadataStatus then
		return
	end
	if LOADER_STATUS_HTML == html then
		logInfo("[status] Unchanged")
		return
	end

	LOADER_STATUS_HTML = html
	logInfo("[status] Updating metadata label", html)
	InMetadataStatus:SetAttrs({ LINKS_Name = html })
end

local function setInfoStatus(info, path)
	local frameCount = getInfoFrameCount(info)
	setStatusHtml(makeStatusHtml("Video loaded", {
		string.format("Path: %s", path),
		string.format("Resolution: %d x %d", info.width or 0, info.height or 0),
		string.format("Frame rate: %s", formatFps(info.fps)),
		string.format("Frames: %s", frameCount > 0 and tostring(frameCount) or "unknown"),
		string.format("Duration: %s", formatSeconds(info.duration)),
		string.format("Codec: %s", info.codecName ~= "" and info.codecName or "unknown"),
		string.format("Pixel format: %s", info.pixelFormat ~= "" and info.pixelFormat or "unknown"),
		string.format("Decoding: %s", (info.hwAccel and info.hwAccel ~= "") and ("Hardware (" .. string.upper(info.hwAccel) .. ")") or "Software"),
	}, false))
end

local function setErrorStatus(title, detail)
	setStatusHtml(makeStatusHtml(title, { tostring(detail or "") }, true))
end

local function createImage(tool, req, width, height, noData)
	local attrs = {
		IMG_Document = tool.Comp,
		{ IMG_Channel = "Red" },
		{ IMG_Channel = "Green" },
		{ IMG_Channel = "Blue" },
		{ IMG_Channel = "Alpha" },
		IMG_Width = math.max(1, math.floor(width or 1)),
		IMG_Height = math.max(1, math.floor(height or 1)),
		IMG_Depth = 5,
		IMG_XScale = 1.0,
		IMG_YScale = 1.0,
		IMG_Quality = not req:IsQuick(),
		IMG_MotionBlurQuality = not req:IsNoMotionBlur(),
	}

	if noData then
		attrs.IMG_NoData = true
	end

	return Image(attrs)
end

local function setNoDataOutput(tool, req, width, height)
	logInfo("[image] Output no-data", "time", req.Time, "size", tostring(width or 1) .. "x" .. tostring(height or 1))
	OutImage:Set(req, createImage(tool, req, width or 1, height or 1, true))
end

local function sampleBytes(ptr, byteCount)
	if not LOADER_LIBAV or not LOADER_LIBAV.ffi or ptr == nil then
		return 0
	end

	local ffi = LOADER_LIBAV.ffi
	if ptr == ffi.NULL then
		return 0
	end

	local data = ffi.cast("const uint8_t*", ptr)
	local limit = math.min(tonumber(byteCount) or 0, 4096)
	local sample = 0
	for i = 0, limit - 1 do
		sample = (sample + tonumber(data[i]) * ((i % 31) + 1)) % 1000000007
	end

	return sample
end

local function copyFrameToImage(outImg, frame)
	local ffi = LOADER_LIBAV.ffi
	local width = tonumber(frame.width) or 0
	local height = tonumber(frame.height) or 0
	local stride = tonumber(frame.stride) or 0
	local byteCount = stride * height
	if width <= 0 or height <= 0 or stride <= 0 then
		return false, "Invalid frame dimensions " .. tostring(width) .. "x" .. tostring(height) .. " stride " .. tostring(stride)
	end

	-- GetScanLine() returns a live, writable array of row pointers into the
	-- image's own pixel memory. The output image is 8-bit RGBA (IMG_Depth 5), so
	-- the array is uint8_t**. On Resolve (ReFu15+) each scanline is RGBA, matching
	-- the bridge's AV_PIX_FMT_RGBA output, so rows copy straight across without a
	-- swizzle. Writing scanlines directly bypasses _FromMemory, which dropped the
	-- bottom scanline (y=0) regardless of source pointer.
	local rawScanlines = outImg:GetScanLine()
	if rawScanlines == nil then
		return false, "Image:GetScanLine returned nil"
	end
	local scanlines = ffi.cast("uint8_t **", rawScanlines)
	if scanlines == ffi.NULL then
		return false, "Image:GetScanLine returned a null pointer"
	end

	-- Fusion stores scanlines bottom-up (scanlines[0] = bottom row); the libav
	-- frame is top-down (row 0 = top). Map image scanline y <- source row
	-- (height-1-y) so the picture lands right-side up, writing every row.
	local srcData = ffi.cast("const uint8_t*", frame.data)
	local rowBytes = width * 4
	for y = 0, height - 1 do
		ffi.copy(scanlines[y], srcData + ((height - 1 - y) * stride), rowBytes)
	end

	logInfo("[image] Wrote scanlines", "frame", tonumber(frame.frame_index), "size", width .. "x" .. height, "stride", stride, "rowBytes", rowBytes, "srcPtr", tostring(frame.data), "srcSample", sampleBytes(frame.data, byteCount))
	return true
end
--endregion Fusion image/status

