local RUNNING_IN_FUSION = FuRegisterClass ~= nil

local TOOL_ID = "Loader_FFmpeg"
local TOOL_TYPE = CT_Tool
local TOOL_NAME = "Loader (FFmpeg)"
local TOOL_DESCRIPTION = "Loads video frames through fuse-local FFmpeg/libav libraries"
local TOOL_ABBREVIATION = "LDFF"
local TOOL_DEVELOPER = "Tangenten"
local TOOL_DEVELOPER_WEBSITE = "https://tangenten.xyz"
local TOOL_VERSION = "0.2.0"

local TOOL_PUBLISHED = false
local TOOL_ENABLE_LOGGING = not TOOL_PUBLISHED
